# Arc — environment variables template
# Copy to `.env` (gitignored) and fill in real values.

# ─── Supabase ──────────────────────────────────────────────────────────────
# Project URL — public (used by client SDK)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Publishable / anon key — public (RLS-protected; safe to ship to client)
# Prefer the `sb_publishable_*` modern format over legacy JWT anon key.
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXX

# ─── Drizzle (server-only; never ship to client) ───────────────────────────
# Direct Postgres connection for `drizzle-kit push` / introspection.
# Get it from Supabase Dashboard → Settings → Database → Connection string (use Transaction Pooler / port 6543).
# DO NOT commit this; .env is gitignored.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# ─── Data source adapters (Stage 1+) ───────────────────────────────────────
# Stage 3 entry — US stocks (Finnhub free tier 60 req/min, register at https://finnhub.io/register)
EXPO_PUBLIC_FINNHUB_API_KEY=

# deprecated, kept for rollback — Alpha Vantage 25 req/day
# EXPO_PUBLIC_ALPHAVANTAGE_API_KEY=

# Market data policy (mobile):
#   cache-first — default in __DEV__: reuse device + Supabase cache; live quotes only on
#                 pull-to-refresh or first-time validate of a new ticker (saves API quota).
#   live        — 15 min price freshness, adapter on cache miss (closer to production).
# EXPO_PUBLIC_MARKET_DATA_POLICY=cache-first

# Stage 1 — FX (Frankfurter, ECB rates, no key needed)
# No env var; adapter is hardcoded since Frankfurter is fully free + key-less.

# Stage 3 — Tushare Pro (repo-root only; tools + Cursor MCP — not bundled to mobile)
# Copy token to `.mcp.json` → `tushareMcp.url` per `.mcp.example.json`, or use root `TUSHARE_TOKEN` here.
TUSHARE_TOKEN=

# Mobile bundle (commit #8): set in `apps/mobile/.env`
# EXPO_PUBLIC_TUSHARE_TOKEN=

# AKShare HTTP wrapper (Phase 2 — deploy services/akshare-wrapper to Vercel first)
# EXPO_PUBLIC_AKSHARE_WRAPPER_URL=https://your-project.vercel.app
# EXPO_PUBLIC_AKSHARE_WRAPPER_TOKEN=
# EXPO_PUBLIC_ENABLE_AKSHARE_CN_FALLBACK=true

COINGECKO_API_KEY=

# Arc — environment variables template
# Copy to `.env` (gitignored) and fill in real values.

# ─── Supabase ──────────────────────────────────────────────────────────────
# Project URL — public (used by client SDK)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Publishable / anon key — public (RLS-protected; safe to ship to client)
# Prefer the `sb_publishable_*` modern format over legacy JWT anon key.
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXX

# ─── Drizzle (server-only; never ship to client) ───────────────────────────
# Direct Postgres connection for `drizzle-kit push` / introspection.
# Get it from Supabase Dashboard → Settings → Database → Connection string (use Transaction Pooler / port 6543).
# DO NOT commit this; .env is gitignored.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_DB_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ─── Data source adapters (Stage 1+) ───────────────────────────────────────
# Stage 1: Alpha Vantage (US stocks) + exchangerate.host (FX) — both free tier
ALPHAVANTAGE_API_KEY=
EXCHANGERATE_HOST_API_KEY=

# Stage 3: more sources
TUSHARE_TOKEN=
COINGECKO_API_KEY=

#!/bin/sh
# Arc pre-commit hook (managed by husky)
# - Secret leak guard (ADR 007 + common API key patterns)
# - Run lint-staged on changed files only (fast, deterministic)
# - Auto-sync .claude/skills → .qoder/skills, .cursor/skills when skills change
# See package.json "lint-staged" config for per-file-pattern actions

# ─── Secret leak guard ───────────────────────────────────────────────────────
# Block commits that add literal secrets in staged diffs.
# Excludes: this hook, ADRs, env templates, seed script (pattern docs only).
SCAN_EXCLUDE=":!.husky/pre-commit :!docs/adr/** :!**/.env*.example :!tools/seed-dev-data.ts"

STAGED_DIFF=$(git diff --cached -U0 -- . $SCAN_EXCLUDE 2>/dev/null || true)
ADDED_LINES=$(printf '%s\n' "$STAGED_DIFF" | grep -E '^\+' | grep -v '^\+\+\+' || true)

LEAKS=""

# Supabase service_role JWT (eyJ...)
SR_LEAKS=$(printf '%s\n' "$ADDED_LINES" \
  | grep -E '(service_role|SERVICE_ROLE_KEY)' \
  | grep -E '[=:][[:space:]]*"?eyJ[A-Za-z0-9_-]{20,}"?' || true)
[ -n "$SR_LEAKS" ] && LEAKS="${LEAKS}
${SR_LEAKS}"

# Live API keys (sk_live_, sb_secret_, etc.)
KEY_LEAKS=$(printf '%s\n' "$ADDED_LINES" \
  | grep -E '[=:][[:space:]]*"?sk_live_[A-Za-z0-9_-]{10,}"?' || true)
[ -n "$KEY_LEAKS" ] && LEAKS="${LEAKS}
${KEY_LEAKS}"

# Postgres URL with non-placeholder password in path
DB_LEAKS=$(printf '%s\n' "$ADDED_LINES" \
  | grep -E 'postgresql://[^[:space:]]+:[^[:space:]/]+@' \
  | grep -viE 'YOUR_|password|changeme|xxx' || true)
[ -n "$DB_LEAKS" ] && LEAKS="${LEAKS}
${DB_LEAKS}"

if [ -n "$LEAKS" ]; then
  echo "❌ Pre-commit blocked: staged diff looks like it contains secrets."
  echo "   Matched lines (truncated):"
  printf '%s\n' "$LEAKS" | head -8 | sed 's/^/     /'
  echo "   Put secrets in .env.dev.local or apps/mobile/.env (both gitignored)."
  echo "   If this is a false positive, use \`git commit --no-verify\` and explain why."
  exit 1
fi

pnpm exec lint-staged

# Skills sync: detect changes in .claude/skills → mirror IDEs (.qoder/, .cursor/)
# Note: mirror dirs are gitignored; sync is local-only
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || exit 0)"
[ -z "$PROJECT_ROOT" ] && exit 0

SYNC_SCRIPT="$PROJECT_ROOT/tools/sync-skills.sh"
CLAUDE_SKILLS="$PROJECT_ROOT/.claude/skills"

# Only run sync if .claude/skills has staged changes
if [ -x "$SYNC_SCRIPT" ] && git diff --cached --name-only -- "$CLAUDE_SKILLS" | grep -q .; then
  bash "$SYNC_SCRIPT"
fi

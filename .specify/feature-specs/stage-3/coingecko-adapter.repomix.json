{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": ".specify/codectx/coingecko-adapter.xml",
    "style": "xml",
    "fileSummary": true,
    "directoryStructure": true,
    "showLineNumbers": true,
    "headerText": "Arc Block A — CoinGecko adapter context bundle. Local only; do not commit."
  },
  "include": [
    ".specify/feature-specs/stage-3/coingecko-adapter-stage-3.md",
    "packages/data-sources/src/adapters/coingecko/**",
    "packages/data-sources/src/registry.ts",
    "packages/data-sources/src/static-symbols.ts",
    "packages/data-sources/__tests__/coingecko*.ts",
    "apps/mobile/src/lib/market-data.ts"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true
  },
  "security": {
    "enableSecurityCheck": true
  }
}

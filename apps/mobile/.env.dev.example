# apps/mobile/.env.dev.example — template for dev-only secrets
#
# Copy to `.env.dev.local` (gitignored) and fill in real values from the
# Supabase Dashboard.
#
# ⚠️  Never commit `.env.dev.local`. The service role key bypasses RLS and
# must stay local-only. The pre-commit hook will reject any commit that
# contains a `service_role` JWT.
#
# These variables are NOT bundled into the mobile app — they are read only
# by tools/seed-dev-data.ts when running `pnpm seed:dev`.

# Dev project URL (Dashboard → Settings → API → Project URL).
# MUST be the DEV project, not prod. The seed script aborts if this contains "prod".
SUPABASE_DEV_URL=https://YOUR_DEV_PROJECT.supabase.co

# Service role key (Dashboard → Settings → API → Project API keys → service_role).
# Starts with `eyJ` (JWT). Bypasses RLS — handle with care.
SUPABASE_DEV_SERVICE_ROLE_KEY=

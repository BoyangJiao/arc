# Arc mobile — copy to `.env` (gitignored). See repo root `.env.example` for server-only vars.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

EXPO_PUBLIC_FINNHUB_API_KEY=
# US historical charts (Finnhub free tier has no candle API)
EXPO_PUBLIC_ALPHAVANTAGE_API_KEY=
EXPO_PUBLIC_TUSHARE_TOKEN=

# AKShare wrapper (deploy services/akshare-wrapper first)
EXPO_PUBLIC_AKSHARE_WRAPPER_URL=
EXPO_PUBLIC_AKSHARE_WRAPPER_TOKEN=
EXPO_PUBLIC_ENABLE_AKSHARE_CN_FALLBACK=true

EXPO_PUBLIC_MARKET_DATA_POLICY=cache-first

# ─── DEV environments (Real / Clean dogfooding — DEV-only) ───────────────────
# See `.specify/feature-specs/cross-stage/real-env-dev-tools.md` §决策 1.
# Use Gmail `+alias` to keep one inbox; Supabase treats each +alias as a
# separate auth user, which is what gives us hard isolation via RLS.
#
# Real Env  = persistent real holdings (Block D Phase 3 雪球对标 prereq + long-term
#             dogfooding). Never wiped by DEV scenario buttons.
# Clean Env = resettable testbed. All scenario seeds (portfolios:*, watchlist:*,
#             rebalance:*, welcome:*, crossMarket:*) land here.
#
# DEV_SEED_EMAIL (in repo-root .env.dev.local) should equal DEV_CLEAN_EMAIL so the
# existing `tools/seed-dev-data.ts` CLI keeps writing into Clean Env.
DEV_REAL_EMAIL=
DEV_CLEAN_EMAIL=

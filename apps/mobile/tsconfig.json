{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@arc/core": [
        "../../packages/core/src/index.ts"
      ],
      "@arc/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@arc/db": [
        "../../packages/db/src/index.ts"
      ],
      "@arc/i18n": [
        "../../packages/i18n/src/index.ts"
      ],
      "@arc/data-sources": [
        "../../packages/data-sources/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}

{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": ".specify/codectx/data-sources.xml",
    "style": "xml",
    "fileSummary": true,
    "directoryStructure": true,
    "showLineNumbers": true,
    "headerText": "Arc data-sources + akshare-wrapper context — generated by Repomix. Local only; do not commit."
  },
  "include": [
    "packages/data-sources/**",
    "services/akshare-wrapper/**",
    "docs/adr/011-multi-source-fallback-and-akshare.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": ["**/.venv/**", "**/__pycache__/**"]
  },
  "security": {
    "enableSecurityCheck": true
  }
}

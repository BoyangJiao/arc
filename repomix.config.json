{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": ".specify/codectx/full-repo.xml",
    "style": "xml",
    "fileSummary": true,
    "directoryStructure": true,
    "showLineNumbers": true,
    "headerText": "Arc monorepo context — generated by Repomix. Local only; do not commit."
  },
  "include": [
    "packages/**",
    "apps/mobile/**",
    "supabase/functions/**",
    "docs/adr/**",
    ".specify/constitution.md",
    ".specify/data-model-invariants.md",
    ".specify/session-state.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": ["**/*.lock", "**/pnpm-lock.yaml"]
  },
  "security": {
    "enableSecurityCheck": true
  }
}

{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": ".specify/codectx/mobile-portfolio.xml",
    "style": "xml",
    "fileSummary": true,
    "directoryStructure": true,
    "showLineNumbers": true,
    "headerText": "Arc mobile Portfolio Tab context — generated by Repomix. Local only; do not commit."
  },
  "include": [
    "apps/mobile/app/(tabs)/index.tsx",
    "apps/mobile/app/portfolio/**",
    "apps/mobile/src/lib/queries/use-portfolio*.ts",
    "apps/mobile/src/lib/queries/use-active-portfolio.ts",
    "apps/mobile/src/lib/store/active-portfolio*.ts",
    "apps/mobile/src/components/Portfolio*.tsx",
    "apps/mobile/src/lib/time-range.ts",
    "packages/ui/src/finance/PortfolioHeroSection.tsx",
    "packages/ui/src/finance/FlippingNumberText.tsx",
    "packages/ui/src/charts/**",
    "packages/i18n/src/locales/en.ts",
    "packages/i18n/src/locales/zh.ts"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true
  },
  "security": {
    "enableSecurityCheck": true
  }
}
